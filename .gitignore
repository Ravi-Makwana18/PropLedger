# ============================================
# PropLedger - Land Deal Management System
# Git Ignore Configuration
# ============================================

# Dependencies
node_modules/
package-lock.json
frontend/node_modules/
backend/node_modules/

# Environment Variables - CRITICAL: Never commit these!
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
backend/.env
backend/.env.*
!backend/.env.example

# System Files
.DS_Store
Thumbs.db
*.log
backend.log
frontend.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build Outputs
dist/
build/
frontend/build/
frontend/dist/
*.tgz

# IDE & Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.sixth/

# Testing & Coverage
coverage/
.nyc_output/
*.test.js.snap

# Deployment
.vercel
.netlify
.cache/

# Temporary Files
*.tmp
*.temp
.temp/
