# ============================================
# PropLedger - Git Ignore Configuration
# ============================================

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Environment Variables ─────────────────────────────────────────────────────
# Ignore all .env files but keep every .env.example committed
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example
!**/.env.example

# ── Build Outputs ─────────────────────────────────────────────────────────────
dist/
build/
*.tgz

# ── System Files ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.sixth/

# ── Testing & Coverage ────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.test.js.snap

# ── Deployment ────────────────────────────────────────────────────────────────
.vercel
.netlify
.cache/

# ── Temporary Files ───────────────────────────────────────────────────────────
*.tmp
*.temp
.temp/
