# ============================================
# PropLedger - Backend Environment Variables
# ============================================
# Copy this file to ../.env (project root) and fill in your values.
# The server loads env from the root directory, NOT from backend/.

# Server Configuration
PORT=5001
NODE_ENV=development

# MongoDB Connection (Atlas recommended)
# Get your URI from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT Configuration
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
JWT_EXPIRE=30d

# Frontend URL (for CORS allowlist)
FRONTEND_URL=https://your-app.vercel.app

# Optional rate-limit tuning
AUTH_RATE_LIMIT_MAX=25
WRITE_RATE_LIMIT_MAX=120

# ── Optional: SMS / OTP Service ─────────────────────────────────────────────
# Twilio
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number

# MSG91 (popular in India)
# MSG91_API_KEY=your_msg91_api_key
# MSG91_SENDER_ID=your_sender_id
