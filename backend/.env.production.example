# ============================================
# PropLedger - Production Environment Variables
# ============================================
# IMPORTANT: Copy this to .env and update with your actual values
# NEVER commit the actual .env file to version control

# Server Configuration
PORT=5001
NODE_ENV=production

# MongoDB Atlas Connection
# Get your connection string from MongoDB Atlas dashboard
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT Configuration
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# Frontend URL (Your Vercel/Netlify deployment)
FRONTEND_URL=https://your-app.vercel.app

# SMS Service (Optional - for OTP functionality)
# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# OR MSG91 (Popular in India)
MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=your_sender_id
