# ============================================
# PropLedger - Frontend Environment Variables
# ============================================
# 1. Copy this file:  cp .env.example .env
# 2. Uncomment the URL that matches your environment
# 3. NEVER commit .env to version control

# Local development
REACT_APP_API_URL=http://localhost:5001

# Production (set this in Vercel dashboard → Settings → Environment Variables)
# REACT_APP_API_URL=https://your-backend.onrender.com
