# ============================================
# PropLedger - Frontend Environment Variables
# ============================================
# 1. Copy this file:  cp .env.example .env
# 2. Set this only for local development or if you intentionally use a separate API origin
# 3. NEVER commit .env to version control

# Local development
REACT_APP_API_URL=http://localhost:5001

# Optional: only enable this if you intentionally need bearer-token fallback
# instead of the safer default httpOnly cookie session flow.
# REACT_APP_ENABLE_TOKEN_FALLBACK=true

# Render-only production: leave REACT_APP_API_URL unset so the app uses same-origin /api requests
