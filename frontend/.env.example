# Frontend Environment Variables
# For local development
REACT_APP_API_URL=http://localhost:5001

# Razorpay Key ID (Public key - safe to expose in frontend)
# Get from: https://dashboard.razorpay.com/app/keys
# Test Mode: Use key starting with rzp_test_
# Live Mode: Use key starting with rzp_live_
REACT_APP_RAZORPAY_KEY_ID=rzp_test_your_key_id

# UPI Payment Configuration
# Your UPI ID for receiving payments (e.g., yourname@okicici, yourname@paytm)
# IMPORTANT: Keep this secure and do not commit actual UPI ID to version control
REACT_APP_UPI_ID=your-upi-id@bank
