{
  "name": "propledger",
  "version": "1.0.0",
  "description": "PropLedger - Land Deal Management System for tracking property deals, payments, and customer enquiries",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "client": "npm start --prefix frontend",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\"",
    "render-build": "npm install && npm install --prefix frontend && npm run build --prefix frontend",
    "seed:admin": "node backend/seedAdmin.js",
    "build:indexes": "node backend/scripts/buildIndexes.js"
  },
  "keywords": [
    "land-management",
    "property-deals",
    "payment-tracking",
    "real-estate",
    "mern-stack"
  ],
  "author": "PropLedger Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/propledger.git"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "nodemon": "^3.1.11",
    "razorpay": "^2.9.6"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
