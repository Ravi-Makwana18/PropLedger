{
  "name": "propledger",
  "private": true,
  "version": "1.0.0",
  "description": "PropLedger - Land Deal Management System for tracking property deals, payments, and customer enquiries",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix backend",
    "dev:client": "npm start --prefix frontend",
    "build": "npm run install:all && npm run build --prefix frontend",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "seed:admin": "node backend/seedAdmin.js",
    "db:indexes": "node backend/scripts/buildIndexes.js",
    "db:migrate-deal-relations": "node backend/scripts/migrateDealRelations.js"
  },
  "keywords": [
    "land-management",
    "property-deals",
    "payment-tracking",
    "real-estate",
    "mern-stack"
  ],
  "author": "Ravi Makwana",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ravi-Makwana18/Propledger.git"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
