# ============================================
# PropLedger - Environment Variables Template
# ============================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env to version control

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development          # change to "production" on server

# ── Database ──────────────────────────────────────────────────────────────────
# Get your URI from: https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
JWT_EXPIRE=30d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your deployed frontend URL (set this on Render / Railway)
FRONTEND_URL=https://your-app.vercel.app
