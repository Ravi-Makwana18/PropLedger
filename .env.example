# ============================================
# PropLedger - Environment Variables Template
# ============================================
# Copy this file to .env and update with your actual values
# NEVER commit the actual .env file to version control

# Server Configuration
PORT=5001
NODE_ENV=development

# MongoDB Connection
# For local MongoDB: mongodb://localhost:27017/propledger
# For MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/propledger

# JWT Configuration
# Generate a strong random secret using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# CSRF Protection - Allowed Origins (comma-separated)
# Add all frontend URLs that should be allowed to make requests
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Admin User Seeder (Optional)
# These credentials will be used when running: npm run seed:admin
ADMIN_NAME=Admin
ADMIN_MOBILE=9999999999
ADMIN_PASSWORD=admin@123

# SMS Service Configuration (Optional - for OTP functionality)
# Uncomment and configure ONE of the following:

# Option 1: MSG91 (Popular in India)
# MSG91_API_KEY=your_msg91_api_key
# MSG91_SENDER_ID=your_sender_id

# Option 2: Twilio (International)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Razorpay Payment Gateway (for subscription payments)
# Get your keys from: https://dashboard.razorpay.com/app/keys
# Test Mode: Use keys starting with rzp_test_
# Live Mode: Use keys starting with rzp_live_
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Razorpay Webhook Secret
# Generate from: https://dashboard.razorpay.com/app/webhooks
# This is used to verify webhook signatures
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
